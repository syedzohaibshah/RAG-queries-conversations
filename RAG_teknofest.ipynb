    {
      "cell_type": "code",
      "source": [
        "\n",
        "# Generate Responses (using Gemini)\n",
        "gemini_model =genai.GenerativeModel('gemini-1.5-pro-latest')\n",
        "\n",
        "def generate_response(query, results, df):\n",
        "    context = \"\"\n",
        "    retrieved_ids = [] #list to store the ids.\n",
        "    for match in results['matches']:\n",
        "        doc_id = match['id']\n",
        "        retrieved_ids.append(doc_id) #add the id to the list.\n",
        "        title = doc_id.split(\"_\")[0]\n",
        "        row = df[df['title'] == title].iloc[0]  # checking from dataframe\n",
        "        context += f\"Title: {row['title']}\\n\"\n",
        "        for message in row['conversation']:\n",
        "            context += f\"Content: {message['content']}\\n\"\n",
        "        context += \"\\n\"\n",
        "\n",
        "    prompt = f\"Answer the following question based on the provided context strictly do not hullicinate:\\n\\nContext:\\n{context}\\n\\nQuestion: {query}\\n\\nAnswer:\"\n",
        "    response = gemini_model.generate_content(prompt)\n",
        "    return response.text, retrieved_ids #return the ids.\n",
        "\n",
        "response, retrieved_ids = generate_response(query, results, df)\n",
        "print(f\"Retrieved IDs: {retrieved_ids}\") #print the ids.\n",
        "print(f\"Response: {response}\")"
      ],
