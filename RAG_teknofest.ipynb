    {
      "cell_type": "code",
      "source": [
        "# preparing data to embed\n",
        "\n",
        "\n",
        "import re\n",
        "\n",
        "\n",
        "  #only title and messages/emails\n",
        "\n",
        "def create_contextual_text(title, conversation):\n",
        "    conversation_text = \" \".join([message['content'] for message in conversation])\n",
        "    return f\"Title: {title}. Conversation: {conversation_text}\"\n",
        "\n",
        "def chunk_text(text, chunk_size=512):\n",
        "    return textwrap.wrap(text, width=chunk_size, break_long_words=False)\n",
        "\n",
        "def create_chunks_and_embed(title, conversation):\n",
        "    text = create_contextual_text(title, conversation)\n",
        "    chunks = chunk_text(text)\n",
        "    embeddings = []\n",
        "    ids = []\n",
        "    for i, chunk in enumerate(chunks):\n",
        "        embedding = genai.embed_content(model=model, content=chunk, task_type=\"retrieval_document\")[\"embedding\"]\n",
        "        embeddings.append(embedding)\n",
        "        #remove non ascii characters from the id.\n",
        "        ascii_id = re.sub(r'[^\\x00-\\x7F]+', '', f\"{title}_{i}\")\n",
        "        ids.append(ascii_id)\n",
        "    return embeddings, chunks, ids"
      ],
      "metadata": {
        "id": "kW5HFUtKnY8y"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import json\n",
        "\n",
        "# Load JSON data from file\n",
        "def load_json_from_file(filepath):\n",
        "    with open(filepath, 'r') as file:\n",
        "        data = json.load(file)\n",
        "    return data\n",
        "\n",
        "# Load your JSON file\n",
        "json_data = load_json_from_file(\"/content/covo_en.json\") #replace with your file name.\n",
        "df = pd.DataFrame(json_data)\n"
      ],
      "metadata": {
        "id": "cv2u1e7KrNg9"
      },
      "execution_count": 7,
      "outputs": []
