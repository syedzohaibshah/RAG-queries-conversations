    {
      "cell_type": "code",
      "source": [
        "#first time for embeddings\n",
        "\n",
        "\n",
        "all_embeddings = []\n",
        "all_ids = []\n",
        "for index_val, row in df.iterrows():\n",
        "    embeddings, chunks, ids = create_chunks_and_embed(row['title'], row['conversation'])\n",
        "    for i, embedding in enumerate(embeddings):\n",
        "        all_embeddings.append(embedding)\n",
        "        all_ids.append(ids[i])\n",
        "\n",
        "# Prepare data for upsert\n",
        "vectors_to_upsert = []\n",
        "for id_val, embedding_val in zip(all_ids, all_embeddings):\n",
        "    vectors_to_upsert.append({\n",
        "        \"id\": id_val,\n",
        "        \"values\": embedding_val\n",
        "    })\n",
        "\n",
        "# Upsert the data\n",
        "index.upsert(vectors=vectors_to_upsert)"
      ],
