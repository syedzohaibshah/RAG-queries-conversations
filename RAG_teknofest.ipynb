        "\n",
        "# Query Pinecone\n",
        "def query_pinecone(query, index, top_k=3):\n",
        "    query_embedding = genai.embed_content(model=model, content=query, task_type=\"retrieval_query\")[\"embedding\"]\n",
        "    results = index.query(vector=query_embedding, top_k=top_k, include_values=False, include_metadata=False)\n",
        "    return results\n",
        "\n",
        "query = \"is it possible to make change after submission of report?\"\n",
        "results = query_pinecone(query, index)\n",
        "\n",
        "\n",
        "print(f\"Query: {query}\")\n",
        "print(f\"Results: {results}\")"
      ],
